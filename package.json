{
  "name": "worldcup-lotto-draft",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "add-group": "node scripts/add-group.mjs",
    "add-results": "node scripts/add-results.mjs",
    "build-books": "node scripts/sportsbook/build-books.mjs",
    "fetch-consensus": "node scripts/sportsbook/fetch-consensus.mjs",
    "refresh-book": "node scripts/sportsbook/fetch-consensus.mjs && node scripts/sportsbook/build-books.mjs --backfill",
    "publish": "node scripts/publish.mjs",
    "deploy": "vite build && rsync -a --delete dist/ ../kdutta9.github.io/worldcup/ && cd ../kdutta9.github.io && git add worldcup && (git diff --cached --quiet || git commit -m 'Deploy: worldcup lotto 26') && git push"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.3.5"
  }
}
